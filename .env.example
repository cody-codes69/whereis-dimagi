# Copy to .env and fill in to enable live mode.
# All keys are optional; unset/omitted falls back to the defaults in config.py.

# ---- Core ----
# WHEREIS_DB_PATH=data/whereis.db
# WHEREIS_DEFAULT_STRATEGY=population          # population | proximity | first
# WHEREIS_MAX_SPEED_KMH=950
# WHEREIS_HOMEBODY_RADIUS_KM=200
# WHEREIS_PHYSICS_ENFORCE=false                # true -> 422 on implausible speed
# WHEREIS_SHARED_SECRET=                        # require X-Shared-Secret header on webhooks

# ---- SMS ----
# WHEREIS_SMS_ADAPTER=simulator                 # simulator | twilio
# WHEREIS_TWILIO_AUTH_TOKEN=
# WHEREIS_TWILIO_VERIFY_SIGNATURE=false

# ---- Email ----
# WHEREIS_EMAIL_ADAPTER=simulator               # simulator | mailgun | imap
# WHEREIS_IMAP_HOST=imap.gmail.com
# WHEREIS_IMAP_USER=
# WHEREIS_IMAP_PASSWORD=
# WHEREIS_IMAP_MAILBOX=INBOX
# WHEREIS_IMAP_POLL_SECONDS=60
